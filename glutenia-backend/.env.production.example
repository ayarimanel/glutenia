NODE_ENV=production
MONGO_URI=mongodb+srv://USERNAME:PASSWORD@CLUSTER.mongodb.net/?retryWrites=true&w=majority&appName=glutenia
# MONGODB_URI can be used instead of MONGO_URI if your host uses that name.
MONGO_DB_NAME=glutenia
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d
CORS_ORIGIN=
GMAIL_USER=your.address@gmail.com
GMAIL_APP_PASSWORD=replace_with_a_16_char_google_app_password
MAIL_FROM=
