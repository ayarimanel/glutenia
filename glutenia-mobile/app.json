{
  "expo": {
    "name": "Glutenia",
    "slug": "glutenia-mobile",
    "version": "1.0.11",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "glutenia",
    "userInterfaceStyle": "light",
    "jsEngine": "jsc",
    "newArchEnabled": false,
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.glutenia.mobile",
      "versionCode": 12,
      "jsEngine": "jsc",
      "permissions": [
        "READ_MEDIA_IMAGES",
        "READ_EXTERNAL_STORAGE"
      ],
      "blockedPermissions": [
        "android.permission.RECORD_AUDIO"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F8F5F0"
      }
    },
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F8F5F0"
    },
    "plugins": [
      "expo-asset",
      "expo-font",
      "expo-localization"
    ],
    "extra": {
      "apiBaseUrl": "http://10.0.2.2:5000/api",
      "eas": {
        "projectId": "fd258cdb-960b-415e-b93d-d1d01d1d3c08"
      }
    }
  }
}
